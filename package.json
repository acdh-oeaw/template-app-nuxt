{
	"name": "@acdh-oeaw/app",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"analyze": "nuxt analyze --dotenv ./.env.local",
		"build": "nuxt build --dotenv ./.env.local",
		"clean": "nuxt cleanup",
		"dev": "nuxt dev --dotenv ./.env.local",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"generate": "nuxt generate --dotenv ./.env.local",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:code:check": "oxlint",
		"lint:code:fix": "oxlint --fix",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:styles:check": "stylelint \"./**/*.@(css|vue)\" --cache --ignore-path ./.gitignore",
		"lint:styles:fix": "stylelint \"./**/*.@(css|vue)\" --cache --fix --ignore-path ./.gitignore",
		"postinstall": "nuxt prepare --dotenv ./.env.local",
		"preinstall": "npx only-allow pnpm",
		"start": "nuxt preview --dotenv ./.env.local",
		"test": "exit 0",
		"test:e2e": "playwright test --config ./e2e/playwright.config.ts",
		"test:e2e:codegen": "playwright codegen",
		"test:e2e:install": "playwright install --with-deps",
		"test:e2e:ui": "pnpm run test:e2e --ui",
		"test:e2e:update-snapshots": "pnpm run test:e2e --update-snapshots",
		"types:check": "nuxt typecheck --dotenv ./.env.local"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "^0.3.7",
		"@fontsource-variable/inter": "^5.2.8",
		"@iconify-json/lucide": "^1.2.105",
		"@iconify-json/simple-icons": "^1.2.80",
		"@nuxt/fonts": "^0.14.0",
		"@nuxt/icon": "^2.2.1",
		"@nuxt/image": "^2.0.0",
		"@nuxt/scripts": "^1.0.5",
		"@nuxtjs/color-mode": "^4.0.0",
		"@nuxtjs/i18n": "^10.3.0",
		"@vueuse/core": "^14.3.0",
		"@vueuse/nuxt": "^14.3.0",
		"lucide-vue-next": "^1.0.0",
		"nuxt": "^4.4.4",
		"pino-http": "^11.0.0",
		"satori": "^0.26.0",
		"sharp": "^0.34.5",
		"valibot": "^1.3.1",
		"vue": "^3.5.33",
		"vue-i18n": "^11.4.0",
		"vue-router": "^5.0.6"
	},
	"devDependencies": {
		"@acdh-oeaw/stylelint-config": "^3.0.3",
		"@acdh-oeaw/tsconfig": "^1.5.1",
		"@dotenvx/dotenvx": "^1.64.0",
		"@nuxt/devtools": "^3.2.4",
		"@nuxt/hints": "1.0.3",
		"@nuxt/kit": "^4.4.4",
		"@nuxt/test-utils": "^4.0.3",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^24.12.2",
		"axe-core": "^4.11.4",
		"axe-playwright": "^2.2.2",
		"eslint-plugin-better-tailwindcss": "^4.5.0",
		"eslint-plugin-playwright": "^2.10.2",
		"is-in-ci": "^2.0.0",
		"lefthook": "^2.1.6",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.60.0",
		"oxlint-tsgolint": "^0.22.1",
		"postcss": "^8.5.13",
		"schema-dts": "^2.0.0",
		"stylelint": "^17.9.1",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^7.3.2",
		"vue-tsc": "^3.2.7"
	},
	"browserslist": {
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		],
		"production": [
			">=0.75%",
			"not dead",
			"not op_mini all"
		]
	},
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config"
	},
	"engines": {
		"node": "24.x"
	},
	"packageManager": "pnpm@11.0.4"
}
