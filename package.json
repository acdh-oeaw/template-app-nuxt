{
	"$schema": "https://www.schemastore.org/package",
	"name": "@acdh-oeaw/app",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"analyze": "nuxt analyze --dotenv ./.env.local",
		"build": "nuxt build --dotenv ./.env.local",
		"clean": "nuxt cleanup",
		"dev": "nuxt dev --dotenv ./.env.local",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"generate": "nuxt generate --dotenv ./.env.local",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:code:check": "oxlint",
		"lint:code:fix": "oxlint --fix",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:styles:check": "stylelint \"./**/*.@(css|vue)\" --cache --ignore-path ./.gitignore",
		"lint:styles:fix": "stylelint \"./**/*.@(css|vue)\" --cache --fix --ignore-path ./.gitignore",
		"postinstall": "nuxt prepare --dotenv ./.env.local",
		"preinstall": "npx only-allow pnpm",
		"start": "nuxt preview --dotenv ./.env.local",
		"test": "exit 0",
		"test:e2e": "playwright test --config ./e2e/playwright.config.ts",
		"test:e2e:codegen": "playwright codegen",
		"test:e2e:install": "playwright install --with-deps",
		"test:e2e:ui": "pnpm run test:e2e --ui",
		"test:e2e:update-snapshots": "pnpm run test:e2e --update-snapshots",
		"types:check": "nuxt typecheck --dotenv ./.env.local"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "^0.3.7",
		"@fontsource-variable/inter": "^5.2.8",
		"@iconify-json/lucide": "^1.2.118",
		"@iconify-json/simple-icons": "^1.2.90",
		"@lucide/vue": "^1.25.0",
		"@nuxt/fonts": "^0.14.0",
		"@nuxt/icon": "^2.3.1",
		"@nuxt/image": "^2.0.0",
		"@nuxt/scripts": "^1.3.1",
		"@nuxtjs/color-mode": "^4.0.1",
		"@nuxtjs/i18n": "^10.4.1",
		"@vueuse/core": "^14.3.0",
		"@vueuse/nuxt": "^14.3.0",
		"nuxt": "^4.4.8",
		"pino-http": "^11.0.0",
		"satori": "^0.28.0",
		"sharp": "^0.35.3",
		"valibot": "^1.4.2",
		"vue": "^3.5.40",
		"vue-i18n": "^11.4.6",
		"vue-router": "^5.2.0"
	},
	"devDependencies": {
		"@acdh-oeaw/stylelint-config": "^3.0.3",
		"@acdh-oeaw/tsconfig": "^1.5.1",
		"@dotenvx/dotenvx": "^2.14.0",
		"@nuxt/devtools": "4.0.0-alpha.7",
		"@nuxt/hints": "1.1.4",
		"@nuxt/kit": "^4.4.8",
		"@nuxt/test-utils": "^4.0.3",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.3",
		"@types/node": "^24.13.3",
		"axe-core": "^4.12.1",
		"axe-playwright": "^2.2.2",
		"eslint-plugin-better-tailwindcss": "^4.6.1",
		"eslint-plugin-playwright": "^2.10.5",
		"is-in-ci": "^2.0.0",
		"lefthook": "^2.1.10",
		"npm-run-all2": "^9.0.2",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"oxlint-tsgolint": "^0.25.0",
		"postcss": "^8.5.19",
		"schema-dts": "^2.0.0",
		"stylelint": "^17.14.0",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vue-tsc": "^3.3.7"
	},
	"browserslist": {
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		],
		"production": [
			">=0.75%",
			"not dead",
			"not op_mini all"
		]
	},
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.14.0",
			"onFail": "download"
		},
		"runtime": {
			"name": "node",
			"version": "^24.18.0",
			"onFail": "download"
		}
	},
	"engines": {
		"runtime": {
			"name": "node",
			"version": "^24.18.0",
			"onFail": "download"
		}
	}
}
