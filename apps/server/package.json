{
	"name": "@acdh-oeaw/app-server",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "",
		"dev": "tsx watch ./src/index.ts",
		"format:check": "prettier . --cache --check --ignore-path ../../.gitignore",
		"format:fix": "pnpm run format:check --write",
		"lint:check": "eslint . --cache --ext .js,.ts --ignore-path ../../.gitignore",
		"lint:fix": "pnpm run lint:check --fix",
		"start": "",
		"test": "exit 0",
		"types:check": "tsc --noEmit",
		"validate": "run-p format:check lint:check types:check test"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "^0.1.12",
		"@hono/node-server": "^1.11.4",
		"hono": "^4.4.7",
		"valibot": "^0.33.2"
	},
	"devDependencies": {
		"@acdh-oeaw/eslint-config": "^1.0.7",
		"@acdh-oeaw/prettier-config": "^2.0.0",
		"@acdh-oeaw/tsconfig": "^1.0.2",
		"@types/node": "^20.14.5",
		"eslint": "^8.57.0",
		"prettier": "^3.3.2",
		"tsx": "^4.15.7",
		"typescript": "^5.4.5"
	},
	"eslintConfig": {
		"extends": [
			"@acdh-oeaw/eslint-config",
			"@acdh-oeaw/eslint-config/strict"
		]
	},
	"lint-staged": {
		"*.@(js|ts)": [
			"eslint --cache --fix",
			"prettier --cache --write"
		],
		"*.!(js|ts)": "prettier --cache --ignore-unknown --write"
	},
	"prettier": "@acdh-oeaw/prettier-config"
}
