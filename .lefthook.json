{
	"pre-commit": {
		"parallel": false,
		"commands": {
			"oxlint": {
				"glob": "**/*.{js,ts,vue}",
				"run": "oxlint --fix {staged_files}",
				"stage_fixed": true
			},
			"stylelint": {
				"glob": "**/*.{css,vue}",
				"run": "stylelint --cache --fix {staged_files}",
				"stage_fixed": true
			},
			"oxfmt": {
				"run": "oxfmt --no-error-on-unmatched-pattern --write {staged_files}",
				"stage_fixed": true
			}
		}
	}
}
